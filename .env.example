# Amanuo OCR System Configuration
APP_NAME=amanuo
DEBUG=false
DATABASE_URL=sqlite+aiosqlite:///./amanuo.db

# Cloud API Keys
GEMINI_API_KEY=
MISTRAL_API_KEY=

# Local VLM Configuration
VLM_BACKEND=ollama
VLM_MODEL=qwen3-vl:4b
VLM_BASE_URL=http://localhost:11434

# Processing
DEFAULT_MODE=auto
MAX_FILE_SIZE_MB=20
MAX_WORKERS=3

# Redis (optional)
REDIS_URL=redis://localhost:6379/0

# Upload storage
UPLOAD_DIR=data/uploads
